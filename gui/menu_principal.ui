  <property name="styleSheet">
   <string notr="true">/* ====== QMainWindow ====== */
QMainWindow {
    background-color: #F5E6D3; /* beige claro */
}

/* ====== Menu Bar ====== */
QMenuBar {
    background-color: #D97706; /* naranja cálido */
    color: #FFF8F0;
    font-family: &quot;Segoe UI&quot;;
    font-size: 14px;
    padding: 4px;
}

/* Item del menú */
QMenuBar::item {
    background: transparent;
    padding: 6px 12px;
    margin: 2px;
    border-radius: 6px;
}

/* Hover */
QMenuBar::item:selected {
    background-color: #F59E0B; /* naranja más claro */
    color: #ffffff;
}

/* ====== QMenu ====== */
QMenu {
    background-color: #FFF7ED; /* crema */
    border: 1px solid #E5A86B;
    padding: 6px;
}

/* Items del menú */
QMenu::item {
    padding: 6px 25px 6px 20px;
    color: #4B2E2E; /* café oscuro */
    border-radius: 4px;
}

/* Hover en items */
QMenu::item:selected {
    background-color: #FDBA74; /* naranja suave */
    color: #3B1F1F;
}

/* Separador */
QMenu::separator {
    height: 1px;
    background: #E5A86B;
    margin: 4px 0px;
}

/* ====== QAction (indirecto) ====== */
/* Nota: QAction no se estiliza directamente, 
   pero se ve reflejado en QMenu::item */

/* ====== Extra: bordes suaves ====== */
QMenuBar, QMenu {
    border-radius: 8px;
}</string>
