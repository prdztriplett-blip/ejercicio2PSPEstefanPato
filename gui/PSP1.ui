   <string notr="true">/* ===== GENERAL ===== */
QWidget {
    background-color: #F5EFE6;
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 14px;
    color: #3E3E3E;
}

/* ===== LABELS ===== */
QLabel {
    color: #4A3F35;
    font-weight: 500;
}

/* ===== LINE EDIT ===== */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #D6CFC7;
    border-radius: 8px;
    padding: 6px 10px;
}

QLineEdit:focus {
    border: 1px solid #A67B5B;
}

/* ===== BOTONES ===== */
QPushButton {
    background-color: #A67B5B;
    color: white;
    border-radius: 10px;
    padding: 8px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #8C684B;
}

QPushButton:pressed {
    background-color: #6F523A;
}

/* ===== BOTONES SECUNDARIOS (tests) ===== */
QPushButton#btn_test1,
QPushButton#btn_test2,
QPushButton#btn_test3,
QPushButton#btn_test4 {
    background-color: #E6D3C3;
    color: #4A3F35;
}

QPushButton#btn_test1:hover,
QPushButton#btn_test2:hover,
QPushButton#btn_test3:hover,
QPushButton#btn_test4:hover {
    background-color: #D6BFAE;
}

/* ===== TABLA ===== */
QTableWidget {
    background-color: #FFFFFF;
    border: 1px solid #D6CFC7;
    gridline-color: #E0D8CF;
    border-radius: 8px;
}

QHeaderView::section {
    background-color: #A67B5B;
    color: white;
    padding: 5px;
    border: none;
}

QTableWidget::item {
    padding: 5px;
}

QTableWidget::item:selected {
    background-color: #D6BFAE;
    color: #3E3E3E;
}</string>
