}

/* Etiquetas */
QLabel {
    color: #5A4A42; /* Café suave */
    font-weight: 500;
}

/* Campos de texto */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #D6CFC7;
    border-radius: 6px;
    padding: 6px 8px;
    color: #3E3E3E;
}

QLineEdit:focus {
    border: 1px solid #C97B63; /* Acento cálido */
}

/* Botones */
QPushButton {
    background-color: #C97B63; /* Terracota */
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #B56A55;
}

QPushButton:pressed {
    background-color: #9E5B49;
}

/* Botón secundario (opcional con objectName) */
QPushButton#secondaryButton {
    background-color: #E6DED6;
    color: #5A4A42;
}

QPushButton#secondaryButton:hover {
    background-color: #D6CFC7;
}</string>
